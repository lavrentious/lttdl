{
  "name": "lttdl",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rm -rf dist ; bun build --production --target=bun --outdir ./dist --root src src",
    "dev": "NODE_ENV=development nodemon --exec bun src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@tobyg74/tiktok-api-dl": "^1.3.7",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.2",
    "grammy": "^1.42.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  }
}